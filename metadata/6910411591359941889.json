1\u0e2e\u0e0a\u0e41\u0e17\u0e47\u0e01\u0e17\u0e35\u0e48\u0e15\u0e49\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e40\u0e02\u0e49\u0e32\u0e23\u0e48\u0e27\u0e21 (#\u0e16\u0e48\u0e32\u0e22\u0e44\u0e1f\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a, #\u0e41\u0e15\u0e48\u0e07\u0e2b\u0e19\u0e49\u0e32\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a, #\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a2020)\n\n\u0e40\u0e19\u0e37\u0e49\u0e2d\u0e2b\u0e32\u0e02\u0e2d\u0e07\u0e41\u0e2e\u0e0a\u0e41\u0e17\u0e47\u0e01:\n1. #\u0e16\u0e48\u0e32\u0e22\u0e44\u0e1f\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a \u0e17\u0e35\u0e48\u0e21\u0e35\u0e40\u0e19\u0e37\u0e49\u0e2d\u0e2b\u0e32\u0e40\u0e01\u0e35\u0e48\u0e22\u0e27\u0e01\u0e31\u0e1a\u0e01\u0e32\u0e23\u0e16\u0e48\u0e32\u0e22\u0e23\u0e39\u0e1b \u0e41\u0e2a\u0e07\u0e44\u0e1f \u0e2b\u0e23\u0e37\u0e2d\u0e41\u0e21\u0e49\u0e01\u0e23\u0e30\u0e17\u0e31\u0e49\u0e07\u0e01\u0e32\u0e23\u0e15\u0e31\u0e14\u0e15\u0e48\u0e2d (\u0e04\u0e2a\u0e23\u0e23\u0e30\u0e27\u0e31\u0e07\u0e40\u0e23\u0e37\u0e48\u0e2d\u0e07 watermark \u0e02\u0e2d\u0e07\u0e41\u0e2d\u0e1b\u0e2d\u0e37\u0e48\u0e19 - \u0e23\u0e30\u0e27\u0e31\u0e07\u0e2b\u0e49\u0e32\u0e21\u0e21\u0e35\u0e1b\u0e38\u0e48\u0e21 quick button \u0e40\u0e21\u0e37\u0e48\u0e2d Record screen)\n2. #\u0e41\u0e15\u0e48\u0e07\u0e2b\u0e19\u0e49\u0e32\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a \u0e41\u0e15\u0e48\u0e07\u0e2b\u0e19\u0e49\u0e32\u0e2b\u0e23\u0e37\u0e2d\u0e41\u0e15\u0e48\u0e07\u0e15\u0e31\u0e27\u0e20\u0e32\u0e22\u0e43\u0e15\u0e49\u0e18\u0e35\u0e21\u0e02\u0e2d\u0e07\u0e0a\u0e48\u0e27\u0e07\u0e40\u0e27\u0e25\u0e32\u0e02\u0e2d\u0e07\u0e01\u0e32\u0e23\u0e40\u0e09\u0e25\u0e34\u0e21\u0e09\u0e25\u0e2d\u0e07 \n3. #\u0e04\u0e23\u0e34\u0e2a\u0e15\u0e4c\u0e21\u0e32\u0e2a2020 \u0e44\u0e21\u0e48\u0e27\u0e48\u0e32\u0e08\u0e30\u0e40\u0e1b\u0e47\u0e19\u0e01\u0e32\u0e23\u0e40\u0e15\u0e49\u0e19 \u0e04\u0e25\u0e34\u0e1b\u0e21\u0e35\u0e21\u0e44\u0e27\u0e23\u0e31\u0e25\u0e15\u0e48\u0e32\u0e07\u0e46 \u0e16\u0e48\u0e32\u0e22\u0e01\u0e31\u0e1a\u0e40\u0e1e\u0e37\u0e48\u0e2d\u0e19 \u0e04\u0e23\u0e2d\u0e1a\u0e04\u0e23\u0e31\u0e27 \u0e2a\u0e31\u0e15\u0e27\u0e4c\u0e40\u0e25\u0e35\u0e49\u0e22\u0e07\u0e04\u0e39\u0e48\u0e43\u0e08 \u0e2a\u0e44\u0e15\u0e25\u0e4c TikTok\n\n\u0e02\u0e2d\u0e07\u0e23\u0e32\u0e07\u0e27\u0e31\u0e25:\n1. \u0e22\u0e2d\u0e14\u0e27\u0e34\u0e27\u0e17\u0e35\u0e48\u0e40\u0e22\u0e2d\u0e30\u0e17\u0e35\u0e48\u0e2a\u0e38\u0e14 5 \u0e23\u0e32\u0e07\u0e27\u0e31\u0e25 \u0e43\u0e19 3 \u0e41\u0e2e\u0e0a\u0e41\u0e17\u0e47\u0e01\n2. \u0e04\u0e27\u0e32\u0e21\u0e04\u0e34\u0e14\u0e2a\u0e23\u0e49\u0e32\u0e07\u0e2a\u0e23\u0e23\u0e04\u0e4c \u0e2b\u0e23\u0e37\u0e2d\u0e23\u0e32\u0e07\u0e27\u0e31\u0e25\u0e02\u0e27\u0e31\u0e0d\u0e43\u0e08\u0e17\u0e35\u0e21\u0e07\u0e32\u0e19 TikTok 5 \u0e23\u0e32\u0e07\u0e27\u0e31\u0e25 \u0e43\u0e19 3 \u0e41\u0e2e\u0e0a\u0e41\u0e17\u0e47\u0e01 \n\n\u0e40\u0e23\u0e34\u0e48\u0e21\u0e15\u0e31\u0e49\u0e07\u0e41\u0e15\u0e48\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48 12 - 25 \u0e18\u0e31\u0e19\u0e27\u0e32\u0e04\u0e21\u0e19\u0e35\u0e49 \n\u0e1b\u0e23\u0e30\u0e01\u0e32\u0e28\u0e1c\u0e39\u0e49\u0e0a\u0e19\u0e30\u0e27\u0e31\u0e19\u0e17\u0e35\u0e48 8 \u0e21\u0e01\u0e23\u0e32\u0e04\u0e21 2021 \u0e17\u0e35\u0e48 facebook \u0e02\u0e2d\u0e07 TikTok Thailand! \n\n\u0e40\u0e25\u0e48\u0e19\u0e41\u0e25\u0e49\u0e27\u0e2d\u0e22\u0e48\u0e32\u0e25\u0e37\u0e21\u0e15\u0e34\u0e14\u0e41\u0e2e\u0e0a\u0e41\u0e17\u0e47\u0e01\u0e43\u0e2b\u0e49\u0e16\u0e39\u0e01\u0e15\u0e49\u0e2d\u0e07\u0e14\u0e49\u0e27\u0e22\u0e19\u0e30!", "profileLarger": "https://p19-common-sign.tiktokcdn-us.com/musically-maliva-obj/c5c266c4a995e4d516ed1c792c96652a~tplv-tiktokx-origin.image?dr=9627&x-expires=1769986800&x-signature=yeRLfAjkYyaPzwG9yW8jM7l0CmE%3D&t=4d5b0474&ps=13740610&shp=81f88b70&shcp=9b759fb9&idc=useast5", "profileMedium": "https://p19-common-sign.tiktokcdn-us.com/musically-maliva-obj/c5c266c4a995e4d516ed1c792c96652a~tplv-tiktokx-origin.image?dr=9627&x-expires=1769986800&x-signature=yeRLfAjkYyaPzwG9y