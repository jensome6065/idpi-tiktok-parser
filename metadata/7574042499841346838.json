], "stickerType": 9}], "isAd": false, "shareEnabled": true, "comments": [], "duetDisplay": 0, "stitchDisplay": 0, "indexEnabled": true, "diversificationLabels": ["Health & Wellness", "Fitness & Health", "Sport & Outdoor"], "locationCreated": "PH", "suggestedWords": [], "contents": [{"desc": "\u201cIf you\u2019ve ever been refused PIP\u2026 this might explain why.", "textExtra": []}, {"desc": "", "textExtra": []}, {"desc": "Most people don\u2019t actually show how their condition affects day-to-day tasks.", "textExtra": []}, {"desc": "They miss out the bad days.", "textExtra": []}, {"desc": "They don\u2019t explain why they can\u2019t do things safely or reliably.", "textExtra": []}, {"desc": "They forget to mention aids they use \u2014 even simple ones.", "textExtra": []}, {"desc": "They skip the help they get from partners, parents or friends.", "textExtra": []}, {"desc": "And they don\u2019t give real examples of what goes wrong.", "textExtra": []}, {"desc": "", "textExtra": []}, {"desc": "#refusedpip #ChronicIllness #pipclaim #PIP ", "textExtra": [{"awemeId": "", "start": 0, "end": 11, "hashtagId": "7507235073905983510", "hashtagName": "refusedpip", "type": 1, "subType": 0, "isCommerce": false}, {"awemeId": "", "start": 12, "end": 27, "hashtagId": "498432", "hashtagName": "chronicillness", "type": 1, "subType": 0, "isCommerce": false}, {"awemeId": "", "start": 28, "end": 37, "hashtagId": "7088368625627136005", "hashtagName": "pipclaim", "type": 1, "subType": 0, "isCommerce": false}, {"awemeId": "", "start": 38, "end": 42, "hashtagId": "455675", "hashtagName": "pip", "type": 1, "subType": 0, "isCommerce": false}]}], "diversificationId": 10096, "collected": false, "channelTags": [], "item_control": {"can_repost": true}, "IsAigc": false, "AIGCDescription": "", "backendSourceEventTracking": "", "CategoryType": 117, "textLanguage": "en", "textTranslatable": true, "authorStatsV2": {"followerCount": "30600", "followingCount": "70", "heart": "68500", "heartCount": "68500", "videoCount": "307", "diggCount": "131", "friendCount": "0"}, "isReviewing": false, "creatorAIComment": {"hasAITopic": false, "categoryList": [], "eligibleVideo": false, "notEligibleReason": 101}}}, "shareMeta": {"title": "Pass PIP Assessment on TikTok", "desc": "\u201cIf you\u2019ve ever been refused PIP\u2026 this might explain why. Most people don\u2019t actually show how their condition affects day-to-day tasks. They miss out the bad days. They don\u2019t explain why they can\u2019t do things safely or reliably. They forget to mention aids they use \u2014 even simple ones. They skip the help they get from partners, parents or friends. And they don\u2019t give real examples of what goes wrong. #refusedpip #ChronicIllness #pipclaim #PIP "}, "statusCode": 0, "statusMsg": ""}